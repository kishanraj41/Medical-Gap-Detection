FROM python:3.11-slim

WORKDIR /app

# Copy and install dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy the application
COPY mock_fhir_server.py .

# Expose port
EXPOSE 8080

# Use exec form and run uvicorn directly
CMD ["uvicorn", "mock_fhir_server:mock_fhir", "--host", "0.0.0.0", "--port", "8080"]
